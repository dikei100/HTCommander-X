<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.AddTorrentFileDialog"
        Title="Add Torrent File"
        Width="420" Height="280"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Click="OkButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel Spacing="8">
            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Filename:" VerticalAlignment="Center" />
                <DockPanel Grid.Row="0" Grid.Column="1">
                    <Button DockPanel.Dock="Right" Content="Browse..." Click="BrowseButton_Click"
                            Padding="8,4" Margin="4,0,0,0" />
                    <TextBox Name="FilenameBox" />
                </DockPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" VerticalAlignment="Center" Margin="0,6,0,0" />
                <TextBox Name="DescriptionBox" Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Mode:" VerticalAlignment="Center" Margin="0,6,0,0" />
                <ComboBox Name="ModeCombo" Grid.Row="2" Grid.Column="1" SelectedIndex="0" Margin="0,6,0,0">
                    <ComboBoxItem Content="Share" />
                    <ComboBoxItem Content="Request" />
                </ComboBox>
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
