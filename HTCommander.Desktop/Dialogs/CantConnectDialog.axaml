<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.CantConnectDialog"
        Title="Connection Failed"
        Width="400" Height="180"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="Unable to Connect" FontSize="16" FontWeight="SemiBold" />
        <TextBlock TextWrapping="Wrap"
                   Text="Could not connect to the radio. Make sure the radio is powered on, Bluetooth is enabled, and the device is paired." />
        <Button Content="Close" Click="CloseButton_Click" HorizontalAlignment="Right"
                Padding="16,4" Margin="0,8,0,0" />
    </StackPanel>
</Window>
