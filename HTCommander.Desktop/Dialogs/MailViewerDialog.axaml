<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.MailViewerDialog"
        Title="View Mail"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Reply" Click="ReplyButton_Click" Padding="12,6" />
            <Button Content="Forward" Click="ForwardButton_Click" Padding="12,6" />
            <Button Content="Delete" Click="DeleteButton_Click" Padding="12,6" />
            <Button Content="Close" Click="CloseButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
            <TextBlock Name="FromLabel" FontWeight="SemiBold" />
            <TextBlock Name="DateLabel" Foreground="Gray" FontSize="11" />
            <TextBlock Name="SubjectLabel" FontSize="16" FontWeight="Bold" Margin="0,4" />
            <Separator />
        </StackPanel>

        <ScrollViewer>
            <TextBlock Name="BodyText" TextWrapping="Wrap" />
        </ScrollViewer>
    </DockPanel>
</Window>
