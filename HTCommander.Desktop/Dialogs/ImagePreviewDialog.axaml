<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.ImagePreviewDialog"
        Title="Image Preview"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="4">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="4,8,4,4">
            <Button Content="Save As..." Click="SaveButton_Click" Padding="12,4" />
            <Button Content="Close" Click="CloseButton_Click" Padding="16,4" />
        </StackPanel>

        <Image Name="PreviewImage" Stretch="Uniform" />
    </DockPanel>
</Window>
