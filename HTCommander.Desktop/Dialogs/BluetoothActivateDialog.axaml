<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.BluetoothActivateDialog"
        Title="Bluetooth Required"
        Width="400" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="Bluetooth Not Available" FontSize="16" FontWeight="SemiBold" />
        <TextBlock TextWrapping="Wrap"
                   Text="Bluetooth must be enabled to connect to your radio. Please enable Bluetooth in your system settings and try again." />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Open Bluetooth Settings" Click="OpenSettings_Click" Padding="12,4" />
            <Button Content="Close" Click="CloseButton_Click" Padding="12,4" />
        </StackPanel>
    </StackPanel>
</Window>
