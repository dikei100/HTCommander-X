<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.ActiveStationSelectorDialog"
        Title="Select Active Station"
        Width="350" Height="400"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Click="OkButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Text="Select a station:" FontWeight="SemiBold" />
            <ListBox Name="StationListBox" MinHeight="200" />
        </StackPanel>
    </DockPanel>
</Window>
