<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.MapLocationDialog"
        Title="Map Location"
        Width="400" Height="260"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Click="OkButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel Spacing="8">
            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Latitude:" VerticalAlignment="Center" />
                <TextBox Name="LatitudeBox" Grid.Row="0" Grid.Column="1" Watermark="e.g. 40.7128" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Longitude:" VerticalAlignment="Center" Margin="0,6,0,0" />
                <TextBox Name="LongitudeBox" Grid.Row="1" Grid.Column="1" Watermark="e.g. -74.0060" Margin="0,6,0,0" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,6,0,0" />
                <TextBox Name="LocationNameBox" Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" />
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
