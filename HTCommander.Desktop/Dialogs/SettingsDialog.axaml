<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.SettingsDialog"
        Title="Settings"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Click="OkButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <TabControl>
            <!-- General tab -->
            <TabItem Header="General">
                <StackPanel Spacing="8" Margin="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Call Sign:" VerticalAlignment="Center" Width="100" />
                        <TextBox Name="CallSignBox" Width="120" />
                        <TextBlock Text="Station ID:" VerticalAlignment="Center" Margin="12,0,0,0" />
                        <ComboBox Name="StationIdCombo" Width="60" />
                    </StackPanel>
                    <CheckBox Name="AllowTransmitCheck" Content="Allow Transmit" />
                    <CheckBox Name="CheckUpdatesCheck" Content="Check for updates on startup" />
                </StackPanel>
            </TabItem>

            <!-- Audio tab -->
            <TabItem Header="Audio">
                <StackPanel Spacing="8" Margin="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Output Device:" VerticalAlignment="Center" Width="100" />
                        <ComboBox Name="OutputDeviceCombo" Width="300" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Input Device:" VerticalAlignment="Center" Width="100" />
                        <ComboBox Name="InputDeviceCombo" Width="300" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Voice tab -->
            <TabItem Header="Voice">
                <StackPanel Spacing="8" Margin="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Language:" VerticalAlignment="Center" Width="100" />
                        <ComboBox Name="VoiceLanguageCombo" Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Voice:" VerticalAlignment="Center" Width="100" />
                        <ComboBox Name="VoiceCombo" Width="200" />
                    </StackPanel>
                    <CheckBox Name="SpeechToTextCheck" Content="Enable Speech-to-Text (Whisper)" />
                </StackPanel>
            </TabItem>

            <!-- GPS tab -->
            <TabItem Header="GPS">
                <StackPanel Spacing="8" Margin="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Serial Port:" VerticalAlignment="Center" Width="100" />
                        <ComboBox Name="GpsPortCombo" Width="150" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Baud Rate:" VerticalAlignment="Center" Width="100" />
                        <ComboBox Name="GpsBaudCombo" Width="150">
                            <ComboBoxItem Content="4800" />
                            <ComboBoxItem Content="9600" />
                            <ComboBoxItem Content="19200" />
                            <ComboBoxItem Content="38400" />
                            <ComboBoxItem Content="57600" />
                            <ComboBoxItem Content="115200" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- APRS tab -->
            <TabItem Header="APRS">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock Text="APRS Routes:" FontWeight="SemiBold" />
                    <DataGrid Name="AprsRoutesGrid" Height="200" AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Width="120" />
                            <DataGridTextColumn Header="Route" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Content="Add" Click="AddRoute_Click" Padding="8,2" />
                        <Button Content="Edit" Click="EditRoute_Click" Padding="8,2" />
                        <Button Content="Delete" Click="DeleteRoute_Click" Padding="8,2" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Servers tab -->
            <TabItem Header="Servers">
                <StackPanel Spacing="12" Margin="8">
                    <StackPanel Spacing="4">
                        <CheckBox Name="WebServerCheck" Content="Enable Web Server" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="24,0,0,0">
                            <TextBlock Text="Port:" VerticalAlignment="Center" />
                            <NumericUpDown Name="WebPortUpDown" Width="100" Minimum="1" Maximum="65535" Value="8080" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <CheckBox Name="AgwpeServerCheck" Content="Enable AGWPE Server" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="24,0,0,0">
                            <TextBlock Text="Port:" VerticalAlignment="Center" />
                            <NumericUpDown Name="AgwpePortUpDown" Width="100" Minimum="1" Maximum="65535" Value="8000" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Winlink tab -->
            <TabItem Header="Winlink">
                <StackPanel Spacing="8" Margin="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Password:" VerticalAlignment="Center" Width="100" />
                        <TextBox Name="WinlinkPasswordBox" Width="200" PasswordChar="*" />
                    </StackPanel>
                    <CheckBox Name="WinlinkUseStationIdCheck" Content="Use Station ID in Winlink address" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
