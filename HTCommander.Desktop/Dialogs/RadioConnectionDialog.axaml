<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.RadioConnectionDialog"
        Title="Radio Connection"
        Width="500" Height="400"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Name="ConnectButton" Content="Connect" Click="ConnectButton_Click"
                    Padding="16,6" IsEnabled="False" />
            <Button Name="DisconnectButton" Content="Disconnect" Click="DisconnectButton_Click"
                    Padding="16,6" IsEnabled="False" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <!-- Radio list -->
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Available Radios" FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <DataGrid Name="RadiosGrid" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single"
                      SelectionChanged="RadiosGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Width="200" Binding="{Binding Name}" />
                    <DataGridTextColumn Header="MAC Address" Width="150" Binding="{Binding Mac}" />
                    <DataGridTextColumn Header="State" Width="*" Binding="{Binding State}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Window>
