<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.BTAccessDeniedDialog"
        Title="Bluetooth Access Denied"
        Width="440" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="Bluetooth Access Denied" FontSize="16" FontWeight="SemiBold" />
        <TextBlock TextWrapping="Wrap"
                   Text="The application does not have permission to access Bluetooth. Please grant Bluetooth access in your system settings and ensure your device is paired." />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Open Settings" Click="OpenSettings_Click" Padding="12,6" />
            <Button Content="Close" Click="CloseButton_Click" Padding="12,6" />
        </StackPanel>
    </StackPanel>
</Window>
