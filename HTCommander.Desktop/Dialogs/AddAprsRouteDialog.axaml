<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.AddAprsRouteDialog"
        Title="Add APRS Route"
        Width="420" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Click="OkButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel Spacing="8">
            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Route Name:" VerticalAlignment="Center" />
                <TextBox Name="RouteNameBox" Grid.Row="0" Grid.Column="1" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Route Path:" VerticalAlignment="Center" Margin="0,6,0,0" />
                <TextBox Name="RoutePathBox" Grid.Row="1" Grid.Column="1"
                         Watermark="CALL1,CALL2,CALL3" Margin="0,6,0,0" />
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
