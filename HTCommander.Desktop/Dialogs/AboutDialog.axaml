<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.AboutDialog"
        Title="About HTCommander-X"
        Width="450" Height="340"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="HTCommander-X" FontSize="24" FontWeight="Bold" />
        <TextBlock Name="VersionText" Text="Version: ..." />
        <TextBlock Text="by Konstantinos Krikis" FontSize="14" />
        <TextBlock TextWrapping="Wrap"
                   Text="Cross-platform open source ham radio commander for Bluetooth-enabled handhelds. Supports UV-PRO, VR-N75, VR-N76, VR-N7500, and other compatible radios." />
        <TextBlock TextWrapping="Wrap"
                   Text="Based on HTCommander by Ylian Saint-Hilaire. Licensed under Apache License 2.0." />
        <StackPanel Spacing="4">
            <Button Name="GithubLink" Content="GitHub Repository (HTCommander-X)" Click="GithubLink_Click"
                    Classes="hyperlink" Padding="0" Background="Transparent" Foreground="Blue" />
            <Button Name="OriginalGithubLink" Content="Original Project (HTCommander)" Click="OriginalGithubLink_Click"
                    Classes="hyperlink" Padding="0" Background="Transparent" Foreground="Blue" />
            <Button Name="LicenseLink" Content="Apache License 2.0" Click="LicenseLink_Click"
                    Classes="hyperlink" Padding="0" Background="Transparent" Foreground="Blue" />
        </StackPanel>
        <Button Content="Close" Click="CloseButton_Click" HorizontalAlignment="Right"
                Padding="16,4" />
    </StackPanel>
</Window>
