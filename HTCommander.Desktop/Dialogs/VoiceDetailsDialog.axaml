<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.VoiceDetailsDialog"
        Title="Voice Message Details"
        Width="420" Height="320"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <Button DockPanel.Dock="Bottom" Content="Close" Click="CloseButton_Click"
                HorizontalAlignment="Right" Padding="16,6" Margin="0,12,0,0" />

        <StackPanel Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Time:" FontWeight="SemiBold" Width="100" />
                <TextBlock Name="TimeText" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Channel:" FontWeight="SemiBold" Width="100" />
                <TextBlock Name="ChannelText" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Encoding:" FontWeight="SemiBold" Width="100" />
                <TextBlock Name="EncodingText" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Source:" FontWeight="SemiBold" Width="100" />
                <TextBlock Name="SourceText" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Destination:" FontWeight="SemiBold" Width="100" />
                <TextBlock Name="DestinationText" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Text:" FontWeight="SemiBold" Width="100" VerticalAlignment="Top" />
                <TextBlock Name="MessageText" TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
