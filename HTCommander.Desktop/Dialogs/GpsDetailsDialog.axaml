<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.GpsDetailsDialog"
        Title="GPS Position"
        Width="400" Height="280"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <Button DockPanel.Dock="Bottom" Content="Close" Click="CloseButton_Click"
                HorizontalAlignment="Right" Padding="16,6" Margin="0,12,0,0" />

        <StackPanel Name="InfoPanel" Spacing="6" />
    </DockPanel>
</Window>
