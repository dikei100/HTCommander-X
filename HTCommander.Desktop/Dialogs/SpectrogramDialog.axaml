<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.SpectrogramDialog"
        Title="Spectrogram"
        Width="700" Height="400"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="4">
        <!-- Top toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource TabHeaderBackground}" Padding="6,4" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Source:" VerticalAlignment="Center" />
                <ComboBox Name="SourceCombo" Width="160" SelectionChanged="SourceCombo_SelectionChanged">
                    <ComboBoxItem Content="Radio Audio" />
                    <ComboBoxItem Content="Microphone" IsEnabled="False" />
                </ComboBox>
                <TextBlock Text="Max Freq:" VerticalAlignment="Center" Margin="12,0,0,0" />
                <ComboBox Name="FreqCombo" Width="90" SelectedIndex="0" SelectionChanged="FreqCombo_SelectionChanged">
                    <ComboBoxItem Content="16 kHz" />
                    <ComboBoxItem Content="8 kHz" />
                    <ComboBoxItem Content="4 kHz" />
                </ComboBox>
                <CheckBox Name="RollCheck" Content="Roll" Margin="12,0,0,0"
                          Click="RollCheck_Click" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,4,0,0">
            <TextBlock Name="StatusText" Text="No audio source" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryText}" />
            <Button Content="Close" Click="CloseButton_Click" Padding="16,6" />
        </StackPanel>

        <!-- Spectrogram display -->
        <Image Name="SpectrogramImage" Stretch="Fill" />
    </DockPanel>
</Window>
