<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.AprsConfigDialog"
        Title="APRS Configuration"
        Width="400" Height="250"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Click="OkButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel Spacing="12">
            <TextBlock Text="APRS Channel Configuration" FontWeight="SemiBold" FontSize="14" />

            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Channel:" VerticalAlignment="Center" />
                <ComboBox Name="ChannelCombo" Grid.Row="0" Grid.Column="1" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Frequency (MHz):" VerticalAlignment="Center" />
                <TextBox Name="FrequencyBox" Grid.Row="1" Grid.Column="1" Text="144.3900" />
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
