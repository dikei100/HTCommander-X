<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.MailClientDebugDialog"
        Title="Mail Client Debug Log"
        Width="600" Height="450"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Clear" Click="ClearButton_Click" Padding="16,6" />
            <Button Content="Close" Click="CloseButton_Click" Padding="16,6" />
        </StackPanel>

        <TextBox Name="LogBox" IsReadOnly="True"
                 FontFamily="Consolas,Menlo,monospace"
                 Background="#1E1E1E" Foreground="#D4D4D4"
                 AcceptsReturn="True" TextWrapping="Wrap" />
    </DockPanel>
</Window>
