<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.AddStationDialog"
        Title="Add Station"
        Width="400" Height="320"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Click="OkButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel Spacing="8">
            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Callsign:" VerticalAlignment="Center" />
                <TextBox Name="CallsignBox" Grid.Row="0" Grid.Column="1" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,6,0,0" />
                <TextBox Name="NameBox" Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" VerticalAlignment="Center" Margin="0,6,0,0" />
                <ComboBox Name="TypeCombo" Grid.Row="2" Grid.Column="1" SelectedIndex="0" Margin="0,6,0,0">
                    <ComboBoxItem Content="Generic" />
                    <ComboBoxItem Content="APRS" />
                    <ComboBoxItem Content="Terminal" />
                    <ComboBoxItem Content="Winlink" />
                    <ComboBoxItem Content="BBS" />
                    <ComboBoxItem Content="Torrent" />
                    <ComboBoxItem Content="AGWPE" />
                </ComboBox>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Description:" VerticalAlignment="Top" Margin="0,6,0,0" />
                <TextBox Name="DescriptionBox" Grid.Row="3" Grid.Column="1" Height="80"
                         AcceptsReturn="True" TextWrapping="Wrap" Margin="0,6,0,0" />
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
