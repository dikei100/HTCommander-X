<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.ImportChannelsDialog"
        Title="Import Channels"
        Width="600" Height="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Import" Click="ImportButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBox Name="FilePathBox" IsReadOnly="True" Width="440" Watermark="Select a CSV file..." />
            <Button Content="Browse..." Click="BrowseButton_Click" Padding="12,6" />
        </StackPanel>

        <DataGrid Name="PreviewGrid" IsReadOnly="True"
                  AutoGenerateColumns="True" />
    </DockPanel>
</Window>
