<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.ImportChannelsDialog"
        Title="Import Channels"
        Width="600" Height="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Name="ImportButton" Content="Import" Click="ImportButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
            <TextBlock Name="InfoText" Text="" FontSize="12" />
        </StackPanel>

        <DataGrid Name="PreviewGrid" IsReadOnly="True" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ch" Width="40" Binding="{Binding Id}" />
                <DataGridTextColumn Header="Name" Width="100" Binding="{Binding Name}" />
                <DataGridTextColumn Header="Frequency" Width="120" Binding="{Binding Frequency}" />
                <DataGridTextColumn Header="Mode" Width="60" Binding="{Binding Mode}" />
                <DataGridTextColumn Header="Bandwidth" Width="80" Binding="{Binding Bandwidth}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
