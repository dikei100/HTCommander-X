<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.EditIdentSettingsDialog"
        Title="Ident Settings"
        Width="400" Height="260"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Click="OkButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel Spacing="8">
            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Ident Text:" VerticalAlignment="Center" />
                <TextBox Name="IdentTextBox" Grid.Row="0" Grid.Column="1" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Interval (sec):" VerticalAlignment="Center" Margin="0,6,0,0" />
                <NumericUpDown Name="IntervalUpDown" Grid.Row="1" Grid.Column="1"
                               Minimum="1" Maximum="7200" Value="600" Increment="1"
                               FormatString="0" Margin="0,6,0,0" />

                <CheckBox Name="EnabledCheck" Grid.Row="2" Grid.Column="1"
                          Content="Enabled" Margin="0,6,0,0" />
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
