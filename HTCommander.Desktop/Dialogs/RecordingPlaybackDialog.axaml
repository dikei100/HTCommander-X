<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.RecordingPlaybackDialog"
        Title="Recording Playback"
        Width="400" Height="180"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <Button DockPanel.Dock="Bottom" Content="Close" Click="CloseButton_Click"
                HorizontalAlignment="Right" Padding="16,6" Margin="0,12,0,0" />

        <StackPanel Spacing="12">
            <TextBlock Name="StatusText" Text="Ready" />
            <ProgressBar Name="PlaybackProgress" Minimum="0" Maximum="100" Value="0" Height="20" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Button Name="PlayButton" Content="Play" Click="PlayButton_Click" Padding="16,6" />
                <Button Name="StopButton" Content="Stop" Click="StopButton_Click" Padding="16,6"
                        IsEnabled="False" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
