<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.MessageDialog"
        Title="Confirm"
        Width="360" Height="160"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="OK" Click="OkButton_Click" Padding="20,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="20,6" />
        </StackPanel>
        <TextBlock Name="MessageText" Text="" TextWrapping="Wrap" VerticalAlignment="Center" />
    </DockPanel>
</Window>
