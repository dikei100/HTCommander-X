<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.SstvSendDialog"
        Title="Send SSTV Image"
        Width="500" Height="480"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Send" Click="SendButton_Click" Padding="16,6" IsEnabled="False"
                    Name="SendButton" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Mode:" VerticalAlignment="Center" Width="80" />
                <ComboBox Name="ModeCombo" Width="240"
                          SelectionChanged="ModeCombo_SelectionChanged" />
            </StackPanel>

            <TextBlock Name="ModeInfoText" Text="" Foreground="#888" FontSize="11" Margin="80,0,0,0" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Select Image..." Click="SelectImage_Click" Padding="8,4" />
                <TextBlock Name="ImagePath" Text="No image selected" VerticalAlignment="Center"
                           Foreground="Gray" />
            </StackPanel>

            <!-- Image preview -->
            <Border Background="{DynamicResource CardBackground}" Height="260" CornerRadius="4">
                <Image Name="PreviewImage" Stretch="Uniform" />
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
