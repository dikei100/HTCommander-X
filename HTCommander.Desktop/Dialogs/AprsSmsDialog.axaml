<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.AprsSmsDialog"
        Title="Send APRS SMS"
        Width="420" Height="260"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Send" Click="SendButton_Click" Padding="16,6" />
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>

        <StackPanel Spacing="8">
            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Destination:" VerticalAlignment="Center" />
                <TextBox Name="DestinationBox" Grid.Row="0" Grid.Column="1"
                         Watermark="Callsign" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Message:" VerticalAlignment="Top" Margin="0,6,0,0" />
                <TextBox Name="MessageBox" Grid.Row="1" Grid.Column="1"
                         Height="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,6,0,0" />
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
