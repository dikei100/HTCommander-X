<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.VoiceTabControl">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource TabHeaderBackground}" Height="46" Padding="10,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="Communication" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Name="VoiceStatus" Text="Idle" VerticalAlignment="Center"
                               Foreground="#888" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="4">
                    <Button Name="SendSstvButton" Content="Send SSTV" Click="SendSstv_Click"
                            Padding="8,2" IsEnabled="False" />
                    <ComboBox Name="ModeCombo" Width="100" SelectedIndex="0">
                        <ComboBoxItem Content="Chat" />
                        <ComboBoxItem Content="Speak" />
                        <ComboBoxItem Content="Morse" />
                        <ComboBoxItem Content="DTMF" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SSTV decode panel (collapsible) -->
        <Border Name="SstvDecodePanel" DockPanel.Dock="Top" Background="{DynamicResource TabHeaderBackground}"
                Padding="8" IsVisible="False">
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="SSTV Decoding:" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Name="SstvModeText" Text="" Foreground="#888" FontSize="12" />
                </StackPanel>
                <ProgressBar Name="SstvProgressBar" Minimum="0" Maximum="100" Value="0" Height="8" />
                <Border Background="{DynamicResource SstvPreviewBackground}" Height="180" CornerRadius="4">
                    <Image Name="SstvPreviewImage" Stretch="Uniform" />
                </Border>
            </StackPanel>
        </Border>

        <!-- Input area at bottom -->
        <Grid DockPanel.Dock="Bottom" Height="40" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Name="VoiceInput" Grid.Column="0" Watermark="Type message..."
                     KeyDown="VoiceInput_KeyDown" />
            <Button Name="TransmitButton" Grid.Column="1" Content="Transmit"
                    Click="TransmitButton_Click" Padding="12,2" Margin="4,0" IsEnabled="False" />
            <Button Name="RecordButton" Grid.Column="2" Content="Record"
                    Click="RecordButton_Click" Padding="8,2" />
        </Grid>

        <!-- Voice messages display -->
        <ScrollViewer Name="MessagesScroller">
            <StackPanel Name="VoiceMessages" Spacing="4" Margin="4" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
