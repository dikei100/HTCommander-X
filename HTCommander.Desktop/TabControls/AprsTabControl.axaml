<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.AprsTabControl">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="Silver" Height="46" Padding="10,0">
            <Grid>
                <TextBlock Text="APRS" VerticalAlignment="Center"
                           FontSize="14" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="4">
                    <TextBlock Name="CallSignLabel" Text="" VerticalAlignment="Center"
                               Margin="0,0,8,0" FontWeight="Bold" />
                    <Button Content="Config" Click="ConfigButton_Click" Padding="8,2" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Transmit bar at bottom -->
        <Grid DockPanel.Dock="Bottom" Height="40" Margin="4"
              Name="TransmitPanel" IsVisible="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox Name="RouteCombo" Grid.Column="0" Width="120" Margin="0,0,4,0" />
            <ComboBox Name="DestCombo" Grid.Column="1" Width="120" Margin="0,0,4,0" />
            <TextBox Name="AprsMessageBox" Grid.Column="2" Watermark="APRS message..." />
            <Button Name="SendAprsButton" Grid.Column="3" Content="Send"
                    Click="SendAprsButton_Click" Padding="12,2" Margin="4,0,0,0" />
        </Grid>

        <!-- Message list -->
        <DataGrid Name="AprsGrid" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Width="140" />
                <DataGridTextColumn Header="From" Width="100" />
                <DataGridTextColumn Header="To" Width="100" />
                <DataGridTextColumn Header="Message" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
