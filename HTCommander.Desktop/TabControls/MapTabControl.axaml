<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
             x:Class="HTCommander.Desktop.TabControls.MapTabControl">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource TabHeaderBackground}" Height="46" Padding="10,0">
            <Grid>
                <TextBlock Text="Map" VerticalAlignment="Center"
                           FontSize="14" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="4">
                    <Button Content="Center" Click="CenterButton_Click" Padding="8,2" />
                    <CheckBox Name="ShowAirplanesCheck" Content="Airplanes"
                              IsChecked="True" Click="ShowAirplanes_Click" />
                    <CheckBox Name="ShowAprsCheck" Content="APRS Stations"
                              IsChecked="True" Click="ShowAprs_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <mapsui:MapControl Name="MapControl" />
    </DockPanel>
</UserControl>
