<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:HTCommander.Desktop.TabControls"
        x:Class="HTCommander.Desktop.MainWindow"
        Title="HTCommander"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400">
    <DockPanel>
        <!-- Top toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8" Spacing="8">
            <Button Name="ConnectButton" Content="Connect Radio" Click="ConnectButton_Click" />
            <Button Name="DisconnectButton" Content="Disconnect" Click="DisconnectButton_Click" IsEnabled="False" />
            <TextBlock Name="StatusText" VerticalAlignment="Center" Text="Not connected" Margin="16,0,0,0" />
        </StackPanel>

        <!-- Left radio info panel -->
        <Border Name="RadioPanel" DockPanel.Dock="Left" Width="260" IsVisible="False"
                BorderBrush="#555" BorderThickness="0,0,1,0" Background="#1A1A2E" Padding="8">
            <ScrollViewer>
                <StackPanel Spacing="8">
                    <!-- Radio name and model -->
                    <TextBlock Name="RadioNameText" Text="VR-N76" FontSize="16" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Name="RadioStateText" Text="Connected" FontSize="12"
                               Foreground="#4CAF50" HorizontalAlignment="Center" />

                    <Separator Background="#444" Margin="0,4" />

                    <!-- VFO A -->
                    <Border Background="#0D1B2A" CornerRadius="4" Padding="8">
                        <StackPanel>
                            <TextBlock Text="VFO A" FontSize="11" Foreground="#888" />
                            <TextBlock Name="VfoAName" Text="--" FontSize="13" Foreground="#64B5F6" FontWeight="SemiBold" />
                            <TextBlock Name="VfoAFreq" Text="--- .--- MHz" FontSize="20" Foreground="#E0E0E0"
                                       FontFamily="Consolas,Liberation Mono,monospace" FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <!-- VFO B -->
                    <Border Background="#0D1B2A" CornerRadius="4" Padding="8">
                        <StackPanel>
                            <TextBlock Text="VFO B" FontSize="11" Foreground="#888" />
                            <TextBlock Name="VfoBName" Text="--" FontSize="13" Foreground="#64B5F6" FontWeight="SemiBold" />
                            <TextBlock Name="VfoBFreq" Text="--- .--- MHz" FontSize="20" Foreground="#E0E0E0"
                                       FontFamily="Consolas,Liberation Mono,monospace" FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <Separator Background="#444" Margin="0,4" />

                    <!-- Signal / TX / Status indicators -->
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,2">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="RSSI" Foreground="#888" FontSize="12" Margin="0,2" />
                        <ProgressBar Name="RssiBar" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="16"
                                     Value="0" Height="14" Margin="8,2,0,2" Foreground="#4CAF50" Background="#333" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="TX" Foreground="#888" FontSize="12" Margin="0,2" />
                        <Border Name="TxIndicator" Grid.Row="1" Grid.Column="1" Height="14" Margin="8,2,0,2"
                                Background="#333" CornerRadius="2">
                            <Border Name="TxIndicatorFill" Background="#333" CornerRadius="2" HorizontalAlignment="Stretch" />
                        </Border>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Battery" Foreground="#888" FontSize="12" Margin="0,4" />
                        <TextBlock Name="BatteryText" Grid.Row="2" Grid.Column="1" Text="--%" Foreground="#E0E0E0"
                                   FontSize="12" Margin="8,4,0,4" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="GPS" Foreground="#888" FontSize="12" Margin="0,2" />
                        <TextBlock Name="GpsText" Grid.Row="3" Grid.Column="1" Text="--" Foreground="#E0E0E0"
                                   FontSize="12" Margin="8,2,0,2" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Squelch" Foreground="#888" FontSize="12" Margin="0,2" />
                        <TextBlock Name="SquelchText" Grid.Row="4" Grid.Column="1" Text="--" Foreground="#E0E0E0"
                                   FontSize="12" Margin="8,2,0,2" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Scan" Foreground="#888" FontSize="12" Margin="0,2" />
                        <TextBlock Name="ScanText" Grid.Row="5" Grid.Column="1" Text="--" Foreground="#E0E0E0"
                                   FontSize="12" Margin="8,2,0,2" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Power" Foreground="#888" FontSize="12" Margin="0,2" />
                        <TextBlock Name="PowerText" Grid.Row="6" Grid.Column="1" Text="--" Foreground="#E0E0E0"
                                   FontSize="12" Margin="8,2,0,2" />
                    </Grid>

                    <Separator Background="#444" Margin="0,4" />

                    <!-- Channel list -->
                    <TextBlock Text="Channels" FontSize="13" Foreground="#AAA" FontWeight="SemiBold" />
                    <ItemsControl Name="ChannelList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,1" Padding="6,3" CornerRadius="3"
                                        Background="{Binding Background}">
                                    <Grid ColumnDefinitions="24,*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Id}" Foreground="#888" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{Binding NameColor}" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding Frequency}" Foreground="#B0B0B0" FontSize="11"
                                                   FontFamily="Consolas,Liberation Mono,monospace" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main tab control -->
        <TabControl Name="MainTabControl" Margin="4">
            <TabItem Header="Debug">
                <tabs:DebugTabControl />
            </TabItem>
            <TabItem Header="Contacts">
                <tabs:ContactsTabControl />
            </TabItem>
            <TabItem Header="Packets">
                <tabs:PacketCaptureTabControl />
            </TabItem>
            <TabItem Header="Terminal">
                <tabs:TerminalTabControl />
            </TabItem>
            <TabItem Header="BBS">
                <tabs:BbsTabControl />
            </TabItem>
            <TabItem Header="Mail">
                <tabs:MailTabControl />
            </TabItem>
            <TabItem Header="Torrent">
                <tabs:TorrentTabControl />
            </TabItem>
            <TabItem Header="APRS">
                <tabs:AprsTabControl />
            </TabItem>
            <TabItem Header="Voice">
                <tabs:VoiceTabControl />
            </TabItem>
            <TabItem Header="Map">
                <tabs:MapTabControl />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
